# Telegram Bot Token
# Get your token from @BotFather on Telegram
BOT_TOKEN=your_bot_token_here

# Comma separated Telegram user IDs who can access admin commands
ADMIN_IDS=123456789

# Optional Local Bot API server
# BOT_API_LOCAL_MODE=true
# BOT_API_BASE_URL=http://127.0.0.1:8081/bot
# BOT_API_BASE_FILE_URL=http://127.0.0.1:8081/file/bot

# Optional overrides
# TEMP_DIR=/tmp/telegram_bot
# DATABASE_PATH=/path/to/bot.db
